@using Microsoft.AspNetCore.Identity
@using WebApplication4.Models.Data
@using WebApplication4.Models;
@using WebApplication4.Models.User

@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item" style="font-size: large; font-weight: bold; color: black; margin-top: 0.8%">
        <a id="manage" class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @UserManager.GetUserName(User)!</a>
    </li>
    <li class="nav-item" style="font-size: large; font-weight: bold; color: black; margin-top: 0.5%">
        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="nav-link btn btn-link text-dark" style="font-size: large; font-weight: bold;">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item" style="font-size: large; font-weight: bold; color: black; margin-top: 0.5%">
        <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item" style="font-size: large; font-weight: bold; color: black; margin-top: 0.5%">
        <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
